---
import { slugifyStr } from "@/utils/slugify";
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import DraftBadge from "./DraftBadge.astro";

export interface Props extends CollectionEntry<"blog"> {
  variant?: "h2" | "h3";
}

const { variant = "h2", data, id, filePath } = Astro.props;

const { title, description, pubDatetime, modDatetime, timezone, draft } = data;

// Astro 동적 태그 — 대문자 변수여야 태그로 렌더된다 (h2/h3 마크업 중복 제거)
const Heading = variant;

const headerProps = {
  style: { viewTransitionName: slugifyStr(title) },
  class:
    "flex items-center text-lg font-medium decoration-dashed hover:underline",
};
---

<li class="my-6">
  <a
    href={getPath(id, filePath)}
    class="inline-block text-lg font-medium text-accent decoration-dashed underline-offset-4 focus-visible:no-underline focus-visible:underline-offset-0"
  >
    <Heading {...headerProps}>
      {draft && <DraftBadge class="me-2" />}
      <span>{title}</span>
    </Heading>
  </a>
  <Datetime {pubDatetime} {modDatetime} {timezone} />
  <p>{description}</p>
</li>
