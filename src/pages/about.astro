---
import { getEntry, render } from "astro:content";
import AboutLayout from "@/layouts/AboutLayout.astro";

const entry = await getEntry("pages", "about");
if (!entry) {
  throw new Error("Content collection entry 'pages/about' not found");
}
const { Content } = await render(entry);
---

<AboutLayout frontmatter={entry.data}>
  <Content />
</AboutLayout>
